# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smartgov-bills

# JWT
JWT_SECRET=your_jwt_secret_key_here

# OpenAI (optional - chatbot works without it using fallback responses)
OPENAI_API_KEY=your_openai_api_key_here

# Razorpay (optional - mock payment mode used without it)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Twilio OTP (optional - OTP logged to console without it)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
