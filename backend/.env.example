# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smartgov-bills

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Groq AI (chatbot)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# PhonePe Payment Gateway
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id_here
PHONEPE_SALT_KEY=your_phonepe_salt_key_here
PHONEPE_SALT_INDEX=1
PHONEPE_API_URL=https://api-preprod.phonepe.com/apis/pg-sandbox/pg/v1/pay
PHONEPE_STATUS_URL=https://api-preprod.phonepe.com/apis/pg-sandbox/pg/v1/status
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Email (Nodemailer) - Used for OTPs, Welcome Emails, and Receipts
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
